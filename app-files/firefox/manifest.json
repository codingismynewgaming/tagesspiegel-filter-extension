{
  "manifest_version": 3,
  "name": "Tagesspiegel Filter",
  "version": "1.0.3",
  "description": "Blenden Sie unerwünschte Sektionen auf Tagesspiegel.de aus - passen Sie Ihr Leseerlebnis an",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "background": {
    "scripts": ["background/background.js"],
    "type": "module"
  },
  "host_permissions": [
    "https://www.tagesspiegel.de/*",
    "https://coral.tagesspiegel.de/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "48": "icons/icon-48.svg",
      "96": "icons/icon-96.svg"
    },
    "default_title": "Tagesspiegel Filter"
  },
  "content_scripts": [
    {
      "matches": ["https://www.tagesspiegel.de/*"],
      "js": ["content/content.js"],
      "css": ["content/styles.css"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://coral.tagesspiegel.de/*"],
      "js": ["content/coral-sort.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "icons": {
    "48": "icons/icon-48.svg",
    "96": "icons/icon-96.svg"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "tagesspiegel-filter@codingismynewgaming",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  }
}
