{
  "manifest_version": 3,
  "name": "Tagesspiegel Filter",
  "version": "1.0.3",
  "description": "Blenden Sie unerwünschte Sektionen auf Tagesspiegel.de aus - passen Sie Ihr Leseerlebnis an",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://www.tagesspiegel.de/*",
    "https://coral.tagesspiegel.de/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "Tagesspiegel Filter"
  },
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.tagesspiegel.de/*"],
      "js": ["browser-polyfill.js", "content/content.js"],
      "css": ["content/styles.css"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://coral.tagesspiegel.de/*"],
      "js": ["content/coral-sort.js"],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": ["https://coral.tagesspiegel.de/*"],
      "js": ["content/coral-sort-main.js"],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["browser-polyfill.js"],
      "matches": ["https://www.tagesspiegel.de/*"]
    }
  ]
}
